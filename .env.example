# Copy to .env and fill in real credentials. NEVER commit .env (already in .gitignore).

# OKX API credentials (User Center → API Keys → Create new)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_SUBACCOUNT_NAME=             # blank = main account

# Trading
SYMBOL=BTC/USDT
ALLOCATION_USDT=500              # max USDT the bot can deploy
DEMO_MODE=true                   # true = OKX demo trading (fake $10k), false = real money

# Strategy (MA_Grid+DCA)
GRID_RANGE_PCT=5.0
GRID_NUM=20
DCA_INTERVAL_HOURS=4
DCA_AMOUNT_USDT=10
MA_REBALANCE_HOURS=6
MA_THRESHOLD_PCT=0.5

# Risk limits
MAX_DRAWDOWN_PCT=20              # soft stop: cancel new orders
KILL_LOSS_PCT=35                 # hard stop: cancel + market-sell base
MAX_DAILY_LOSS_PCT=7             # daily circuit breaker
MAX_ORDER_USDT=100               # per-order safety cap
HEALTH_CHECK_SEC=30              # equity polling interval

LOG_LEVEL=INFO
